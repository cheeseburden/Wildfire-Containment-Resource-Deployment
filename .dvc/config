# DVC Configuration for Data & Model Versioning
# ================================================
# Track large data files and model artifacts with DVC
# Remote storage configured for reproducibility

[core]
    remote = local_storage
    autostage = true

['remote "local_storage"']
    url = /tmp/pyroshield-dvc-storage

# To configure cloud remote:
# dvc remote add s3_remote s3://pyroshield-bucket/dvc
# dvc remote modify s3_remote access_key_id <KEY>
# dvc remote modify s3_remote secret_access_key <SECRET>
