# ============================================================
# .gitignore — PyroShield AI
# ============================================================

# Byte-compiled / optimised
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# MLflow
mlruns/
mlartifacts/
mlflow.db

# DVC cache
.dvc/cache/
.dvc/tmp/

# Data (tracked by DVC)
data/raw/
data/processed/

# Logs
logs/
*.log

# Docker
.dockerignore

# Test artifacts
tests/_test_*.pkl
test-results.xml
.pytest_cache/
.coverage
htmlcov/

# Build
dist/
build/
*.egg-info/
